# Aplicacao
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000
TRUST_PROXY=0

# MySQL Hostinger ou ambiente local
# DATABASE_URL=mysql://usuario:senha@host:3306/banco
DB_HOST=localhost
DB_PORT=3306
DB_NAME=brutusmaq
DB_USER=brutusmaq_app
DB_PASSWORD=troque-esta-senha
DB_CONNECTION_LIMIT=10
DB_SSL=false

# Segredos com pelo menos 32 caracteres aleatorios
SESSION_SECRET=troque-por-um-segredo-longo-e-aleatorio
ANALYTICS_SECRET=troque-por-outro-segredo-longo-e-aleatorio
MFA_ENCRYPTION_KEY=troque-por-um-terceiro-segredo-longo-e-aleatorio
BACKUP_ENCRYPTION_KEY=troque-por-um-quarto-segredo-longo-e-aleatorio
REQUIRE_ADMIN_MFA=true
SESSION_HOURS=8

# Primeiro administrador; usado somente por npm run db:seed
ADMIN_NAME=Administrador Brutusmaq
ADMIN_EMAIL=admin@brutusmaq.com.br
ADMIN_PASSWORD=troque-por-uma-senha-forte-com-12-caracteres

# E-mail SMTP. Deixe SMTP_HOST vazio para apenas salvar as solicitacoes.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Site Brutusmaq <contato@brutusmaq.com.br>
CONTACT_TO=contato@brutusmaq.com.br

# Uploads persistentes. Na Hostinger, configure um caminho que sobreviva ao deploy.
UPLOAD_DIR=storage/uploads
MAX_UPLOAD_MB=8
BACKUP_DIR=storage/backups

# Separadas por virgula. BASE_URL ja e permitido automaticamente.
ALLOWED_ORIGINS=
